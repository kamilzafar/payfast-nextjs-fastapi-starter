# EditorConfig — https://editorconfig.org
# Top-level settings for the PayFast platform repository.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Python: PEP 8 four-space indent.
[*.py]
indent_style = space
indent_size = 4

# TypeScript / JavaScript / JSON / YAML / Markdown: two-space indent.
[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml,md,mdx,css,scss}]
indent_style = space
indent_size = 2

# Markdown: preserve trailing whitespace (two-space = hard line break).
[*.{md,mdx}]
trim_trailing_whitespace = false

# Makefiles require literal tabs for recipe lines.
[Makefile]
indent_style = tab

[makefile]
indent_style = tab

[*.mk]
indent_style = tab

# Go uses tabs.
[*.go]
indent_style = tab
