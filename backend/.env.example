# Core
ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/payfast
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5432/payfast_test

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_SECRET
JWT_LIFETIME_SECONDS=3600
REFRESH_TOKEN_LIFETIME_SECONDS=604800

# CORS (JSON list)
CORS_ORIGINS=["http://localhost:3000"]

# PayFast (phase 2/3)
PAYFAST_MERCHANT_ID=your_merchant_id
PAYFAST_SECURED_KEY=your_secured_key
PAYFAST_BASE_URL=https://ipguat.apps.net.pk
PAYFAST_RETURN_URL=http://localhost:8000/payfast/return
PAYFAST_CANCEL_URL=http://localhost:8000/payfast/cancel
PAYFAST_WEBHOOK_SECRET=your_webhook_secret

# Frontend (phase 3 — redirect targets)
FRONTEND_URL=http://localhost:3000

# Phase 5 — Scheduler
SCHEDULER_ENABLED=true

# Phase 6 — Rate limiting (slowapi)
RATE_LIMIT_ENABLED=true

# Phase 6 — Logging (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=INFO

# Phase 5 — Dunning / renewal
DUNNING_GRACE_DAYS=7
DUNNING_REMINDER_DAYS=[3,5]
RENEWAL_PRE_NOTICE_DAYS=3

# Phase 5 — Email (smtp = MailHog dev; resend = production)
EMAIL_BACKEND=smtp
SMTP_HOST=localhost
SMTP_PORT=1025
EMAIL_FROM=billing@payfast.local
RESEND_API_KEY=
